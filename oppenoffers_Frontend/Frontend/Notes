/****** Object:  StoredProcedure [dbo].[updateAnnonce]    Script Date: 2026-02-11 5:39:15 PM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO

ALTER PROCEDURE [dbo].[updateAnnonce]
    @Id UNIQUEIDENTIFIER,
    @Numero NVARCHAR(225),
    @Delai INT,
    @Journal NVARCHAR(255),
    @Heure_Ouverture TIME(7),
    @Date_Overture DATE,
    @Date_Publication DATE
AS
BEGIN
    SET NOCOUNT ON;

    BEGIN TRY
        -- Check if the record exists
        IF NOT EXISTS (SELECT 1 FROM dbo.ANNOUNCES WHERE Id = @Id)
        BEGIN
            RETURN 1005;
        END

        -- Update fields including Numero
        UPDATE dbo.ANNOUNCES
        SET 
            Numero = @Numero,
            Delai = @Delai,
            Journal = @Journal,
            Heure_Ouverture = @Heure_Ouverture,
            Date_Overture = @Date_Overture,
            Date_Publication = @Date_Publication
        WHERE Id = @Id;

        RETURN 0; 
    END TRY

    BEGIN CATCH
        RETURN 5000;
    END CATCH
END

