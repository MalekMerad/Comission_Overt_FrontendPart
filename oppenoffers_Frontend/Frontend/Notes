USE [PlisFlow]
GO
/****** Object:  StoredProcedure [dbo].[GetOperationById]    Script Date: 2026-02-11 5:39:55 PM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO

ALTER PROC [dbo].[GetOperationById]
    @op UNIQUEIDENTIFIER
AS 
BEGIN
    SET NOCOUNT ON;

	--1. Operation
	SELECT * FROM OPERATIONS 
	WHERE Id = @op;
    
	-- 2. Lots
    SELECT * FROM LOTS 
    WHERE id_Operation = @op 
      AND Status = 1;

    -- 3. Announces
    SELECT * FROM ANNOUNCES 
    WHERE Id_Operation = @op;

    -- 4. Suppliers WITH NumeroRetrait (Filtered for exclusivity)
    WITH SupplierWithRetrait AS (
        SELECT 
            F.*,
            R.NumeroRetrait,
            R.OperationID
        FROM FOURNISSEURS F
        INNER JOIN retrait_cahier_charges R 
            ON F.Id = R.SupplierID
        WHERE R.OperationID = @op 
          AND R.Status = 1 
          AND F.Status = 1
          AND NOT EXISTS (
              SELECT 1 
              FROM retrait_cahier_charges R2 
              WHERE R2.SupplierID = F.Id 
                AND R2.OperationID <> @op
          )
    )
    SELECT * FROM SupplierWithRetrait;

END
